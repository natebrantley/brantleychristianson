# Clerk (auth – required for dashboard, sign-in, and Supabase user sync)
# Get keys: https://dashboard.clerk.com
# For local dev: use Development keys (pk_test_... / sk_test_...) – production keys only work on brantleychristianson.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
# Optional: redirect after sign-in/sign-up (defaults from SignIn component)
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk webhook (sync user.created / user.updated to Supabase users table)
# Configure in Clerk Dashboard → Webhooks; use signing secret here.
# CLERK_WEBHOOK_SECRET=whsec_...

# Supabase (user records and optional RLS; used with Clerk JWT)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (server-only; webhook and admin)

# MailerLite (consultation form → add contact to list)
# Get your API token: Integrations → MailerLite API → Generate new token
# Create custom fields in MailerLite (Subscribers → Fields) if you want: message, source, market, building_name
MAILERLITE_API_TOKEN=your-mailerlite-api-token

# Optional: group ID to add consultation leads to (e.g. "Consultation"). Find in MailerLite under Groups.
# MAILERLITE_GROUP_ID=your-group-id

# Optional: Google Maps Embed API key – enables embedded map on condo building pages
# Get key: https://developers.google.com/maps/documentation/embed/get-api-key
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-embed-api-key

# Optional: Google Analytics 4 measurement ID for event tracking
# Example: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# When set, basic pageview and custom event tracking will be enabled.

# Repliers.io (real estate CRM / lead management)
# Get your API key from your Repliers dashboard.
# Both REPLIERS_API_KEY and REPLIERS_DEFAULT_AGENT_ID are required for lead sync (consultation form → Repliers client).
# REPLIERS_API_KEY=your-repliers-api-key
# REPLIERS_DEFAULT_AGENT_ID=12345

# Walk Score API – walk/transit/bike scores (e.g. for property or area pages)
# Get key: https://www.walkscore.com/professional/api.php
# WALKSCORE_API_KEY=your-walkscore-api-key
